{
  "enabled": true,
  "name": "Rust 代码检查",
  "description": "修改 Rust 文件后自动运行 cargo check 检查编译错误",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/*.rs"]
  },
  "then": {
    "type": "runShellCommand",
    "command": "cd src-tauri && cargo check --message-format=short 2>&1 | head -50"
  },
  "workspaceFolderName": "KiroCode",
  "shortName": "rust-check",
  "fileName": "rust-check.kiro.hook"
}
