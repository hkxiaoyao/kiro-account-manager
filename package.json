{
  "name": "kiro-account-manager",
  "private": true,
  "version": "1.8.3",
  "description": "Kiro Account Manager - 管理 Kiro IDE 账号，支持多账号切换和配额监控",
  "author": "hj01857655",
  "license": "CC-BY-NC-SA-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hj01857655/kiro-account-manager"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev --no-dev-server",
    "build": "vite build",
    "build:release": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release.ps1",
    "preview": "vite preview",
    "tauri": "tauri",
    "extract": "lingui extract",
    "compile": "lingui compile",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:check": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-release-pipeline.ps1"
  },
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@mantine/core": "7.15.2",
    "@mantine/hooks": "7.15.2",
    "@tanstack/react-virtual": "3.13.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "2.6",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "2.10",
    "clsx": "2.1.1",
    "i18next": "25.7.2",
    "lucide-react": "0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "2.6.0",
    "react-i18next": "16.4.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@lingui/cli": "5.6.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "2.10.1",
    "@vitejs/plugin-react": "^4.2.1",
    "standard-version": "9.5.0",
    "tailwindcss": "^4.0.0",
    "terser": "5.44.1",
    "vite": "^5.0.8"
  }
}
